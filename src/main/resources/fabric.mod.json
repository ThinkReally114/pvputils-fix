{
  "schemaVersion": 1,
  "id": "pvputils-skija-patch",
  "version": "${version}",
  "name": "PVPUtils-fix",
  "icon": "icon.png",
  "description": "Patches PVPUtils to support Windows and Linux by pre-loading the correct Skia native library.",
  "authors": [
    "ThinkReally114"
  ],
  "contact": {
    "github": "https://github.com/ThinkReally114/pvputils-fix"
  },
  "license": "MIT",
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.pvp_utils_skija_patch.SkijaPatchMod"
    ]
  },
  "mixins": [
    "pvputils-skija-patch.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.18.4",
    "minecraft": "~1.21.11",
    "java": ">=21",
    "fabric-api": "*"
  },
  "suggests": {
    "pvp-utils": "*"
  }
}
